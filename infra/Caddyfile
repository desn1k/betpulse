# Caddy reverse proxy with automatic TLS. PUBLIC_DOMAIN must be the production
# hostname. The frontend is the public entrypoint; the API is proxied under
# /api and /docs.

{$PUBLIC_DOMAIN:localhost} {
	encode zstd gzip

	# Security headers (a fuller CSP is added in the Phase 13 hardening pass).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "0"
		-Server
	}

	handle /healthz {
		respond "ok" 200
	}

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /docs* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
