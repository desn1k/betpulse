# =============================================================================
#  Football Analytics Platform — environment template
#  Copy to .env and fill in. NEVER commit .env. Rotate every secret before prod.
#  Generate secrets with:  openssl rand -hex 32
# =============================================================================

# --- Core -------------------------------------------------------------------
ENVIRONMENT=development                 # development | staging | production
DEBUG=false
APP_NAME=football-analytics
PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
DEFAULT_LOCALE=ru                       # ru | en
TZ=Europe/Moscow

# --- Security ---------------------------------------------------------------
SECRET_KEY=                             # openssl rand -hex 32 — signs JWT access tokens
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
# Master key used to envelope-encrypt provider/LLM/TOTP secrets at rest. Losing it
# means losing every stored secret. Back it up separately from the DB.
DATA_ENCRYPTION_KEY=                    # openssl rand -hex 32
CORS_ALLOWED_ORIGINS=http://localhost:3000
ADMIN_2FA_REQUIRED=true

# Argon2id password hashing (see backend/app/core/security.py for the rationale)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536            # 64 MiB
ARGON2_PARALLELISM=4

# Auth cookies (refresh token is httpOnly+SameSite=Strict; CSRF is double-submit).
# Keep AUTH_COOKIE_SECURE=true in prod; set false only for local http dev.
AUTH_COOKIE_SECURE=true
EMAIL_VERIFICATION_REQUIRED=false       # feature flag for the require_verified gate

# Login abuse controls: per-IP rate limit + per-account exponential backoff lockout
RATE_LIMIT_LOGIN_PER_MINUTE=5           # per client IP
LOGIN_MAX_FAILURES=5                    # per account before backoff starts
LOCKOUT_BASE_SECONDS=30                 # doubles each further failure...
LOCKOUT_MAX_SECONDS=3600                # ...capped here (never a permanent lock)
RATE_LIMIT_PROMO_PER_HOUR=10

# --- Bootstrap admin (created by `make seed`; empty password → one-time printed) -
# `make seed` runs `python -m app.bootstrap create-admin`. The admin is created
# with must_change_password=true; admin routes stay locked until it is changed.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                         # leave empty to auto-generate a one-time password

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=football
POSTGRES_USER=football
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://football:${POSTGRES_PASSWORD}@postgres:5432/football
# Optional read replica (leave empty on a single server)
DATABASE_READ_URL=

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# --- Object storage (S3-compatible: MinIO locally, any provider in prod) -----
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_ARTIFACTS=ml-artifacts        # MLflow models
S3_BUCKET_BACKUPS=backups               # WAL-G / dumps
S3_FORCE_PATH_STYLE=true

# --- MLflow -----------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_ROOT=s3://ml-artifacts

# --- Football data providers -------------------------------------------------
# Keys are normally added through the ADMIN UI (encrypted at rest).
# These are only a bootstrap fallback for local dev / CI.
# football-data.co.uk needs no key (free CSV, historical + closing odds).
FOOTBALL_DATA_COUK_ENABLED=true
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_DAILY_LIMIT=7500
API_FOOTBALL_PER_MINUTE_LIMIT=300

# --- Ingestion & live --------------------------------------------------------
LIVE_POLL_INTERVAL_SECONDS=60           # /fixtures?live=all cadence (self-rescheduling)
# In-play recompute is triggered after each successful poll (event-driven), not a
# fixed timer; recompute runs only when a match's score/minute actually changed.
PROBABILITY_SWING_PUSH_THRESHOLD=0.10   # 10 percentage points → push
LIVE_REPLAY_WINDOW_SECONDS=300          # SSE Last-Event-ID reconnect replay bound (5 min)
ENABLED_LEAGUES=EPL,LALIGA,SERIEA,BUNDESLIGA,LIGUE1,UCL,UEL,UECL,RPL

# --- Model governance --------------------------------------------------------
ACCURACY_WINDOW_DAYS=90                 # rolling out-of-sample window
CONSENSUS_WEIGHT_MODE=auto              # auto (∝ accuracy) | manual (admin sliders)
CHAMPION_MIN_SAMPLES=300                # below this a method cannot become champion
MODEL_RETENTION_VERSIONS=10             # champions are kept forever regardless
RETRAIN_CRON=0 4 * * *                  # nightly retrain + re-evaluation

# --- LLM (any OpenAI-compatible endpoint) ------------------------------------
# Configurable from the admin UI too; these are defaults.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1200
LLM_DAILY_TOKEN_BUDGET=200000           # hard stop when exceeded
LLM_CACHE_TTL_SECONDS=21600

# --- Push notifications ------------------------------------------------------
# Swing pushes go to Telegram (Bot HTTP API) and Web Push (VAPID). Delivery is
# rate-limited per fixture and retried exactly once before being discarded.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=                 # ops alerts: backup/CI/ingest failures
WEBPUSH_VAPID_PUBLIC_KEY=               # base64url EC P-256 public key
WEBPUSH_VAPID_PRIVATE_KEY=              # base64url 32-byte P-256 private scalar
WEBPUSH_CONTACT_EMAIL=admin@example.com # becomes the VAPID mailto: subject
PUSH_RATE_LIMIT_SECONDS=300             # at most one push per fixture per window
PUSH_RETRY_DELAY_SECONDS=30             # delay before the single retry

# --- Email (verification, password reset) ------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# --- Backups -----------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=6
BACKUP_ENCRYPTION_PUBLIC_KEY=           # age recipient key; private key stored OFFLINE
RESTORE_DRILL_CRON=0 5 * * 0            # weekly restore verification
RPO_ALERT_MINUTES=15                    # alert if newest good backup is older than this

# --- Observability -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
METRICS_ENABLED=true                    # /metrics (Prometheus), protected

# --- Legal / compliance ------------------------------------------------------
AGE_GATE_ENABLED=true                   # 18+ gate on first visit
AGE_GATE_CONSENT_DAYS=180
DISCLAIMER_REQUIRED=true                # footer + every prediction card + backtester
